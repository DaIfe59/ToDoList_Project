@* TextInputDialog.razor *@
@if (IsVisible)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                </div>

                <div class="modal-body">
                    <p>Введите название новой категории:</p>
                    <input class="form-control"
                           @bind="InputText"
                           @onkeydown="HandleKeyDown" />
                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="OnOk">ОК</button>
                    <button class="btn btn-secondary" @onclick="OnCancel">Отмена</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Диалог";

    [Parameter] public EventCallback<string> OnOkClicked { get; set; }
    [Parameter] public EventCallback OnCancelClicked { get; set; }

    private string InputText = "";

    private async Task OnOk()
    {
        await OnOkClicked.InvokeAsync(InputText);
        InputText = "";
    }

    private async Task OnCancel()
    {
        await OnCancelClicked.InvokeAsync();
        InputText = "";
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OnOk();

        if (e.Key == "Escape")
            await OnCancel();
    }
}