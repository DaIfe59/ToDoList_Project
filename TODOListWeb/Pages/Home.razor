@page "/"
@using TODOListWeb.Models
@using TODOListWeb.Services
@inject ApiService Api

<PageTitle>To-Do List</PageTitle>

<div class="container mt-4">
    <h3>Список задач</h3>

    <!-- Добавление задачи -->
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text" class="form-control" placeholder="Название задачи..."
                   @bind="TaskTitle"
                   @onkeydown="HandleKeyDown" />
        </div>
        <div class="col-md-2">
            <select class="form-select" @bind="SelectedCategoryId">
                <option value="">Без категории</option>
                @foreach (var cat in Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="AddTask" disabled="@IsLoading">Добавить</button>
        </div>
    </div>

    <!-- Список задач -->
    <div class="row">
        <div class="col-md-9">
            <div class="list-group border" style="height: 300px; overflow-y: auto;">
                @foreach (var task in Tasks)
                {
                    <button type="button"
                            class="list-group-item list-group-item-action @(SelectedTask?.Id == task.Id ? "active" : "")"
                            @onclick="() => SelectedTask = task">
                        @task.Title (@(task.Category?.Name ?? "Нет категории"))
                    </button>
                }
            </div>

            @if (IsLoading)
            {
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                </div>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="text-danger fw-bold mt-2">@ErrorMessage</div>
            }

            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="text-success fst-italic mt-1">@StatusMessage</div>
            }
        </div>

        <!-- Панель действий -->
        <div class="col-md-3">
            <button class="btn btn-danger w-100 mb-2" @onclick="DeleteTask" disabled="@(SelectedTask == null || IsLoading)">Удалить задачу</button>
            <button class="btn btn-warning w-100 mb-4" @onclick="EditTask" disabled="@(SelectedTask == null || IsLoading)">Изменить задачу</button>

            <button class="btn btn-outline-secondary w-100 mb-2" @onclick="ShowAddCategoryDialog" disabled="@IsLoading">Создать категорию</button>
            <button class="btn btn-outline-danger w-100" @onclick="ShowRemoveCategoryDialog" disabled="@IsLoading || Categories.Count == 0">Удалить категорию</button>
        </div>
    </div>
</div>

<!-- Модальные окна -->
<TextInputDialog IsVisible="@isAddCategoryDialogVisible"
                 Title="Добавить категорию"
                 OnOkClicked="OnAddCategoryDialogOk"
                 OnCancelClicked="OnAddCategoryDialogCancel" />

<RemoveCategoryDialog IsVisible="@isRemoveCategoryDialogVisible"
                      Categories="@Categories"
                      OnCategoryDeleted="OnCategoryDeleted"
                      OnCancelClicked="OnRemoveCategoryDialogCancel" />

<TaskEditDialog IsVisible="isEditTaskDialogVisible"
                InitialText="@SelectedTask?.Title"
                OnClose="OnEditTaskDialogClosed" />

@code {
    private string TaskTitle { get; set; } = "";
    private int? SelectedCategoryId { get; set; }
    private TaskItem? SelectedTask { get; set; }

    private List<TaskItem> Tasks = new();
    private List<Category> Categories = new();

    private bool IsLoading = false;
    private string ErrorMessage = "";
    private string StatusMessage = "";

    // Модальные окна
    private bool isAddCategoryDialogVisible = false;
    private bool isRemoveCategoryDialogVisible = false;
    private bool isEditTaskDialogVisible = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            Tasks = await Api.GetTasksAsync();
            Categories = await Api.GetCategoriesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка при загрузке данных: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ===== Задачи =====
    private async Task AddTask()
    {
        if (string.IsNullOrWhiteSpace(TaskTitle)) return;

        var task = new TaskItem { Title = TaskTitle, CategoryId = SelectedCategoryId };
        try
        {
            await Api.AddTaskAsync(task);
            Tasks.Add(task);
            TaskTitle = "";
            StatusMessage = $"Задача '{task.Title}' добавлена!";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка при добавлении задачи: {ex.Message}";
        }
    }

    private async Task DeleteTask()
    {
        if (SelectedTask == null) return;

        try
        {
            await Api.DeleteTaskAsync(SelectedTask.Id);
            Tasks.Remove(SelectedTask);
            StatusMessage = $"Задача '{SelectedTask.Title}' удалена!";
            SelectedTask = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка при удалении задачи: {ex.Message}";
        }
    }

    private void EditTask()
    {
        if (SelectedTask != null)
            isEditTaskDialogVisible = true;
    }

    private async Task OnEditTaskDialogClosed(string? result)
    {
        isEditTaskDialogVisible = false;

        if (!string.IsNullOrWhiteSpace(result) && SelectedTask != null)
        {
            SelectedTask.Title = result;
            StatusMessage = "Задача обновлена!";
            try
            {
                await Api.UpdateTaskAsync(SelectedTask.Id, SelectedTask);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Ошибка при обновлении задачи: {ex.Message}";
            }
        }
    }

    // ===== Категории =====
    private void ShowAddCategoryDialog() => isAddCategoryDialogVisible = true;
    private void OnAddCategoryDialogCancel() => isAddCategoryDialogVisible = false;

    private async Task OnAddCategoryDialogOk(string categoryName)
    {
        isAddCategoryDialogVisible = false;
        if (string.IsNullOrWhiteSpace(categoryName)) return;

        var newCategory = new Category { Name = categoryName };
        try
        {
            await Api.AddCategoryAsync(newCategory);
            Categories.Add(newCategory);
            StatusMessage = $"Категория '{categoryName}' добавлена!";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка при добавлении категории: {ex.Message}";
        }
    }

    private void ShowRemoveCategoryDialog() => isRemoveCategoryDialogVisible = true;
    private void OnRemoveCategoryDialogCancel() => isRemoveCategoryDialogVisible = false;

    private async Task OnCategoryDeleted(Category? deletedCategory)
    {
        isRemoveCategoryDialogVisible = false;
        if (deletedCategory == null) return;

        try
        {
            await Api.DeleteCategoryAsync(deletedCategory.Id);
            Categories.Remove(deletedCategory);
            StatusMessage = $"Категория '{deletedCategory.Name}' удалена!";
            if (SelectedCategoryId == deletedCategory.Id)
                SelectedCategoryId = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка при удалении категории: {ex.Message}";
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddTask();
    }
}